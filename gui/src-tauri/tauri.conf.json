{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EctoLedger",
  "identifier": "io.ectoledger.agent-ledger",
  "version": "0.6.4",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run icon:generate && npm run build"
  },
  "app": {
    "macOSPrivateApi": false,
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* http://localhost:* http://10.0.0.0/8:* http://172.16.0.0/12:* http://192.168.0.0/16:* ws://127.0.0.1:* ws://localhost:*; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data:"
    },
    "windows": [
      {
        "label": "_bundler_placeholder",
        "title": "EctoLedger",
        "width": 1200,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "msi",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      },
      "nsis": {
        "displayLanguageSelector": true,
        "installerIcon": "icons/icon.ico",
        "installMode": "both",
        "languages": ["English"]
      },
      "wix": {
        "language": "en-US",
        "upgradeCode": "B8F3E9A1-4D72-4F5A-9C8E-1A2B3C4D5E6F"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
