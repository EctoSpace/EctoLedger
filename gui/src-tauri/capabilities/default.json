{
  "identifier": "default",
  "description": "Default capability for main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "shell:allow-execute",
    "shell:allow-spawn",
    "dialog:default",
    "fs:default",
    "fs:allow-write-file",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$DOCUMENT/ectoledger/**/*" },
        { "path": "$DOWNLOAD/**/*.iac" },
        { "path": "$DOWNLOAD/ectoledger-*.json" }
      ]
    }
  ]
}
