#!/usr/bin/env bash
# =============================================================================
#  Ecto Ledger — One-Click Launcher (Linux)
#  Usage:  ./ectoledger-linux [FLAGS]
#
#  FLAGS:
#    --demo           Zero-config demo: SQLite DB, auto-detect/install LLM, seed demo session
#    --setup          Build & install deps only, then exit (no servers started)
#    --rebuild        Force cargo build even if binary already exists
#    --backend-only   Start backend server without the GUI
#    --reset-db       Wipe embedded Postgres data and start fresh
#    --help           Show this message
# =============================================================================

set -euo pipefail

# ── Colours ──────────────────────────────────────────────────────────────────
RESET="\033[0m"
BOLD="\033[1m"
RED="\033[0;31m"
YELLOW="\033[0;33m"
GREEN="\033[0;32m"
CYAN="\033[0;36m"
PURPLE="\033[0;35m"

# ── Paths ──────────────────────────────────────────────────────────────────
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BINARY="$SCRIPT_DIR/target/release/ectoledger"
GUI_DIR="$SCRIPT_DIR/gui"
PID_FILE="${XDG_RUNTIME_DIR:-$HOME/.local/run}/ectoledger_backend.pid"
mkdir -p "$(dirname "$PID_FILE")"
LOG_FILE="$SCRIPT_DIR/ectoledger.log"

# ── Flags ───────────────────────────────────────────────────────────────────
FLAG_SETUP=false
FLAG_REBUILD=false
FLAG_BACKEND_ONLY=false
FLAG_RESET_DB=false
FLAG_DEMO=false

for arg in "$@"; do
  case "$arg" in
    --demo)          FLAG_DEMO=true ;;
    --setup)         FLAG_SETUP=true ;;
    --rebuild)       FLAG_REBUILD=true ;;
    --backend-only)  FLAG_BACKEND_ONLY=true ;;
    --reset-db)      FLAG_RESET_DB=true ;;
    --help|-h)
      echo "Usage: ./ectoledger-linux [--demo] [--setup] [--rebuild] [--backend-only] [--reset-db] [--help]"
      echo ""
      echo "  --demo           Zero-config demo: SQLite DB, auto-detect/install LLM, seed session"
      echo "  --setup          Build & install deps only (no servers started)"
      echo "  --rebuild        Force cargo build even if binary exists"
      echo "  --backend-only   Start backend server without the GUI"
      echo "  --reset-db       Wipe the embedded Postgres data dir and start fresh"
      exit 0
      ;;
    *)
      echo -e "${RED}Unknown flag: $arg${RESET}"
      echo "Usage: ./ectoledger-linux [--demo] [--setup] [--rebuild] [--backend-only] [--reset-db] [--help]"
      exit 1
      ;;
  esac
done

# ── Banner ───────────────────────────────────────────────────────────────────
R1="\033[1;31m"
R2="\033[1;33m"
R3="\033[1;32m"
R4="\033[1;36m"
R5="\033[1;34m"
R6="\033[1;35m"

echo ""
echo -e "${R1}  ██╗██████╗  ██████╗ ███╗   ██╗ ██████╗██╗      █████╗ ██████╗ ${RESET}"
echo -e "${R2}  ██║██╔══██╗██╔═══██╗████╗  ██║██╔════╝██║     ██╔══██╗██╔══██╗${RESET}"
echo -e "${R3}  ██║██████╔╝██║   ██║██╔██╗ ██║██║     ██║     ███████║██║  ██║${RESET}"
echo -e "${R4}  ██║██╔══██╗██║   ██║██║╚██╗██║██║     ██║     ██╔══██║██║  ██║${RESET}"
echo -e "${R5}  ██║██║  ██║╚██████╔╝██║ ╚████║╚██████╗███████╗██║  ██║██████╔╝${RESET}"
echo -e "${R6}  ╚═╝╚═╝  ╚═╝ ╚═════╝ ╚═╝  ╚═══╝ ╚═════╝╚══════╝╚═╝  ╚═╝╚═════╝ ${RESET}"
echo -e "${CYAN}  Agent Ledger 2026${RESET}"
